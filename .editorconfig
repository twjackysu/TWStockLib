root = true

[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{csproj,props,targets,slnx,yml,yaml,json}]
indent_size = 2

[*.cs]
# 現代化：使用 file-scoped namespace
csharp_style_namespace_declarations = file_scoped:warning
